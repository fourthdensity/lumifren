# Flask Security
SECRET_KEY=your_secret_key_here
# Set to 'true' to enable global Basic Auth
ENABLE_AUTH=true

# Credentials for both Chat and Admin
APP_USER=admin
APP_PASS=lumifren2026

# Kimi Settings (Direct to Nvidia)
KIMI_PROXY_URL=https://integrate.api.nvidia.com/v1/chat/completions
KIMI_API_KEY=your_nvidia_api_key_here
KIMI_MODEL=moonshotai/kimi-k2.5

# GitHub Copilot (GitHub Models API)
GITHUB_TOKEN=your_github_pat_here
GITHUB_MODEL=gpt-4o

# Google Gemini (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379

# Foundry Settings
FOUNDRY_API_KEY=your_foundry_api_key_here
FOUNDRY_MODEL=gpt-oss-120b
FOUNDRY_PROJECT_ENDPOINT=your_foundry_project_endpoint_here
